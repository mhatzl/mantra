{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReportNavigationSchema",
  "type": "object",
  "required": [
    "products",
    "root_sources"
  ],
  "properties": {
    "products": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ProductNavigation"
      }
    },
    "root_sources": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/SourceNavigation"
      }
    },
    "schema_version": {
      "description": "The schema version. [req(\"exchange.versioned\")]",
      "type": [
        "string",
        "null"
      ]
    }
  },
  "definitions": {
    "ProductMetadata": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "base": {
          "description": "Optional baseline of the product. e.g. git branch or commit hash\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        },
        "homepage": {
          "description": "Optional link to the homepage of the product.\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "description": "The product ID.\n\nTODO: map to requirement",
          "type": "string"
        },
        "license": {
          "description": "Optional license of the product.\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "description": "The name of the product.\n\nTODO: map to requirement",
          "type": "string"
        },
        "repository": {
          "description": "Optional link to the repository of the product.\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "description": "Optional version of the product.\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ProductNavigation": {
      "type": "object",
      "required": [
        "product",
        "reviews",
        "root_requirements",
        "root_test_runs"
      ],
      "properties": {
        "product": {
          "$ref": "#/definitions/ProductMetadata"
        },
        "reviews": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ReviewReference"
          }
        },
        "root_requirements": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RequirementReference"
          }
        },
        "root_test_runs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TestRunReference"
          }
        }
      }
    },
    "RequirementReference": {
      "type": "object",
      "required": [
        "id",
        "optional",
        "product_id",
        "state"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "optional": {
          "type": "boolean"
        },
        "product_id": {
          "type": "string"
        },
        "state": {
          "$ref": "#/definitions/RequirementState"
        }
      }
    },
    "RequirementState": {
      "type": "string",
      "enum": [
        "failed",
        "verified",
        "skipped",
        "unverified",
        "deprecated",
        "excluded"
      ]
    },
    "ReviewReference": {
      "type": "object",
      "required": [
        "name",
        "product_id",
        "state",
        "utc_date"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "product_id": {
          "type": "string"
        },
        "state": {
          "$ref": "#/definitions/ReviewState"
        },
        "utc_date": {
          "type": "string"
        }
      }
    },
    "ReviewState": {
      "type": "string",
      "enum": [
        "obsolete",
        "valid"
      ]
    },
    "SourceNavigation": {
      "type": "object",
      "required": [
        "source"
      ],
      "properties": {
        "files": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/SourceReference"
          }
        },
        "folder": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/SourceNavigation"
          }
        },
        "source": {
          "$ref": "#/definitions/SourceReference"
        }
      }
    },
    "SourceReference": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string"
        }
      }
    },
    "TestRunReference": {
      "type": "object",
      "required": [
        "name",
        "product_id",
        "state",
        "utc_date"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "product_id": {
          "type": "string"
        },
        "state": {
          "$ref": "#/definitions/TestState"
        },
        "utc_date": {
          "type": "string"
        }
      }
    },
    "TestState": {
      "description": "Possible states a test run or test case may be in.",
      "oneOf": [
        {
          "description": "Test failed.",
          "type": "string",
          "enum": [
            "failed"
          ]
        },
        {
          "description": "Test passed successfully.",
          "type": "string",
          "enum": [
            "passed"
          ]
        },
        {
          "description": "Test was skipped in the related test run.",
          "type": "string",
          "enum": [
            "skipped"
          ]
        },
        {
          "description": "Test is in an unknown state.\n\nThis likely indicates that a test case did not finish execution, and is treated as *failed* state. [req(\"testcov.test_case.state.unknown\")]",
          "type": "string",
          "enum": [
            "unknown"
          ]
        },
        {
          "description": "Test is obsolete.\n\nObsolete tests must not be considered for coverage analysis.",
          "type": "string",
          "enum": [
            "obsolete"
          ]
        }
      ]
    }
  }
}