{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvidenceMatrixSchema",
  "type": "object",
  "required": [
    "product",
    "requirements"
  ],
  "properties": {
    "product": {
      "$ref": "#/definitions/ProductMetadata"
    },
    "requirements": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/RequirementEvidence"
      }
    },
    "version": {
      "description": "The schema version. [req(\"exchange.versioned\")]",
      "type": [
        "string",
        "null"
      ]
    }
  },
  "definitions": {
    "ProductMetadata": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "base": {
          "description": "Optional baseline of the product. e.g. git branch or commit hash\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        },
        "homepage": {
          "description": "Optional link to the homepage of the product.\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "description": "The product ID.\n\nTODO: map to requirement",
          "type": "string"
        },
        "license": {
          "description": "Optional license of the product.\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "description": "The name of the product.\n\nTODO: map to requirement",
          "type": "string"
        },
        "repository": {
          "description": "Optional link to the repository of the product.\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "description": "Optional version of the product.\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "RequirementCoverageByTestsOverview": {
      "type": "object",
      "required": [
        "test_cases",
        "test_runs"
      ],
      "properties": {
        "test_cases": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TestCaseReference"
          }
        },
        "test_runs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TestRunReference"
          }
        }
      }
    },
    "RequirementEvidence": {
      "type": "object",
      "required": [
        "id",
        "manual_verification",
        "optional",
        "state",
        "title"
      ],
      "properties": {
        "children": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/RequirementReference"
          }
        },
        "covered_by": {
          "anyOf": [
            {
              "$ref": "#/definitions/RequirementCoverageByTestsOverview"
            },
            {
              "type": "null"
            }
          ]
        },
        "id": {
          "type": "string"
        },
        "manual_verification": {
          "type": "boolean"
        },
        "optional": {
          "type": "boolean"
        },
        "parents": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/RequirementReference"
          }
        },
        "reviewed_in": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/ReviewReference"
          }
        },
        "state": {
          "$ref": "#/definitions/RequirementState"
        },
        "title": {
          "type": "string"
        }
      }
    },
    "RequirementReference": {
      "type": "object",
      "required": [
        "id",
        "optional",
        "product_id",
        "state"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "optional": {
          "type": "boolean"
        },
        "product_id": {
          "type": "string"
        },
        "state": {
          "$ref": "#/definitions/RequirementState"
        }
      }
    },
    "RequirementState": {
      "type": "string",
      "enum": [
        "failed",
        "verified",
        "skipped",
        "unverified",
        "deprecated",
        "ignored"
      ]
    },
    "ReviewReference": {
      "type": "object",
      "required": [
        "name",
        "product_id",
        "state",
        "utc_date"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "product_id": {
          "type": "string"
        },
        "state": {
          "$ref": "#/definitions/ReviewState"
        },
        "utc_date": {
          "type": "string"
        }
      }
    },
    "ReviewState": {
      "type": "string",
      "enum": [
        "obsolete",
        "valid"
      ]
    },
    "TestCaseReference": {
      "type": "object",
      "required": [
        "product_id",
        "state",
        "test_case_name",
        "test_run_date",
        "test_run_name"
      ],
      "properties": {
        "product_id": {
          "type": "string"
        },
        "state": {
          "$ref": "#/definitions/TestState"
        },
        "test_case_name": {
          "type": "string"
        },
        "test_run_date": {
          "type": "string"
        },
        "test_run_name": {
          "type": "string"
        }
      }
    },
    "TestRunReference": {
      "type": "object",
      "required": [
        "name",
        "product_id",
        "state",
        "utc_date"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "product_id": {
          "type": "string"
        },
        "state": {
          "$ref": "#/definitions/TestState"
        },
        "utc_date": {
          "type": "string"
        }
      }
    },
    "TestState": {
      "description": "Possible states a test run or test case may be in.",
      "oneOf": [
        {
          "description": "Test failed.",
          "type": "string",
          "enum": [
            "failed"
          ]
        },
        {
          "description": "Test passed successfully.",
          "type": "string",
          "enum": [
            "passed"
          ]
        },
        {
          "description": "Test was skipped in the related test run.",
          "type": "string",
          "enum": [
            "skipped"
          ]
        },
        {
          "description": "Test is in an unknown state.\n\nThis likely indicates that a test case did not finish execution, and is treated as *failed* state. [req(\"testcov.test_case.state.unknown\")]",
          "type": "string",
          "enum": [
            "unknown"
          ]
        },
        {
          "description": "Test is obsolete.\n\nObsolete tests must not be considered for coverage analysis.",
          "type": "string",
          "enum": [
            "obsolete"
          ]
        }
      ]
    }
  }
}