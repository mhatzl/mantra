{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductsOverviewReport",
  "type": "object",
  "required": [
    "product_reports",
    "summary"
  ],
  "properties": {
    "product_reports": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ProductOverviewReport"
      }
    },
    "summary": {
      "$ref": "#/definitions/ProductsSummary"
    }
  },
  "definitions": {
    "Aggregated": {
      "type": "object",
      "required": [
        "cnt",
        "percentage"
      ],
      "properties": {
        "cnt": {
          "type": "integer",
          "format": "int64"
        },
        "percentage": {
          "type": "number",
          "format": "float"
        }
      }
    },
    "AnnotationsOverview": {
      "type": "object",
      "required": [
        "coverage_excludes",
        "elements",
        "traces"
      ],
      "properties": {
        "coverage_excludes": {
          "$ref": "#/definitions/CoverageExcludesOverview"
        },
        "elements": {
          "$ref": "#/definitions/ElementsOverview"
        },
        "traces": {
          "$ref": "#/definitions/TracesOverview"
        }
      }
    },
    "CodeBlock": {
      "description": "A generic code block that is linked to a trace. [req(\"trace.code_block\")]",
      "type": "object",
      "required": [
        "kind",
        "span"
      ],
      "properties": {
        "content_hash": {
          "description": "The SHA256 content hash of the code block.",
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "description": "The kind of the code block.",
          "allOf": [
            {
              "$ref": "#/definitions/CodeBlockKind"
            }
          ]
        },
        "span": {
          "description": "The line span of the code block. [req(\"trace.code_block.span\")]",
          "allOf": [
            {
              "$ref": "#/definitions/LineSpan"
            }
          ]
        }
      }
    },
    "CodeBlockKind": {
      "description": "The code block kind.",
      "type": "string",
      "enum": [
        "other",
        "if",
        "else_if",
        "else",
        "loop",
        "while",
        "for",
        "match"
      ]
    },
    "CoverageExclude": {
      "description": "Coverage exclusion information found in a file. e.g. markers in code files may be used to exclude uncoverable lines from being considered for code coverage metrics.\n\nTODO: add requirement trace",
      "type": "object",
      "required": [
        "comment",
        "kind"
      ],
      "properties": {
        "comment": {
          "description": "Mandatory comment on why the exclusion is acceptable.",
          "type": "string"
        },
        "kind": {
          "description": "The kind of coverage exclusion.",
          "allOf": [
            {
              "$ref": "#/definitions/CoverageExcludeKind"
            }
          ]
        }
      }
    },
    "CoverageExcludeKind": {
      "description": "The kind of coverage exclusion that was found in a file.",
      "oneOf": [
        {
          "description": "Excludes a code span from coverage metrics. Both lines are inclusive!",
          "type": "object",
          "required": [
            "block"
          ],
          "properties": {
            "block": {
              "type": "object",
              "required": [
                "end",
                "start"
              ],
              "properties": {
                "end": {
                  "type": "integer",
                  "format": "int64"
                },
                "start": {
                  "type": "integer",
                  "format": "int64"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Excludes one line from coverage metrics.",
          "type": "object",
          "required": [
            "line"
          ],
          "properties": {
            "line": {
              "type": "integer",
              "format": "int64"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "CoverageExcludesOverview": {
      "type": "object",
      "required": [
        "files"
      ],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CoverageExcludesPerFile"
          }
        }
      }
    },
    "CoverageExcludesPerFile": {
      "type": "object",
      "required": [
        "excludes",
        "file_hash",
        "filepath"
      ],
      "properties": {
        "excludes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CoverageExclude"
          }
        },
        "file_hash": {
          "type": "string"
        },
        "filepath": {
          "type": "string"
        }
      }
    },
    "CoveredByTestsOverview": {
      "type": "object",
      "required": [
        "test_cases",
        "test_runs"
      ],
      "properties": {
        "test_cases": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TestCaseReference"
          }
        },
        "test_runs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TestRunReference"
          }
        }
      }
    },
    "CoveredLinesSummary": {
      "type": "object",
      "required": [
        "covered",
        "excluded",
        "overridden",
        "total",
        "uncovered"
      ],
      "properties": {
        "covered": {
          "$ref": "#/definitions/Aggregated"
        },
        "excluded": {
          "$ref": "#/definitions/Aggregated"
        },
        "overridden": {
          "$ref": "#/definitions/Aggregated"
        },
        "total": {
          "type": "integer",
          "format": "int64"
        },
        "uncovered": {
          "$ref": "#/definitions/Aggregated"
        }
      }
    },
    "ElementKind": {
      "description": "Defines supported element kinds. [req(\"trace.element.kind\")]",
      "oneOf": [
        {
          "description": "Variant that should be used if no other one fits.",
          "type": "string",
          "enum": [
            "other"
          ]
        },
        {
          "description": "Marks an element as a test or test case.",
          "type": "string",
          "enum": [
            "test"
          ]
        },
        {
          "description": "A module or package.",
          "type": "string",
          "enum": [
            "module"
          ]
        },
        {
          "description": "A function or method.",
          "type": "string",
          "enum": [
            "function"
          ]
        },
        {
          "description": "A variable or static.",
          "type": "string",
          "enum": [
            "variable"
          ]
        },
        {
          "description": "A constant.",
          "type": "string",
          "enum": [
            "const"
          ]
        },
        {
          "description": "A type, struct, enum, class, or union.",
          "type": "string",
          "enum": [
            "type"
          ]
        },
        {
          "description": "A field or property.",
          "type": "string",
          "enum": [
            "field"
          ]
        },
        {
          "description": "A trait, interface, or other abstract type.",
          "type": "string",
          "enum": [
            "trait"
          ]
        },
        {
          "description": "A function signature or virtual function that has no *body*. It is likely declared inside a trait/interface.",
          "type": "string",
          "enum": [
            "function_signature"
          ]
        }
      ]
    },
    "ElementOverview": {
      "type": "object",
      "required": [
        "definition_line",
        "kind",
        "name",
        "span"
      ],
      "properties": {
        "covered_by": {
          "anyOf": [
            {
              "$ref": "#/definitions/CoveredByTestsOverview"
            },
            {
              "type": "null"
            }
          ]
        },
        "definition_line": {
          "description": "The line the element is defined at.\n\n**Note:** This might differ from `span.start`, because in Rust for example, attributes & doc-comments are part of the span, but the definition of an element starts below them.\n\nTODO: trace req",
          "type": "integer",
          "format": "int64"
        },
        "ident": {
          "description": "The fully qualified identifier of the element. [req(\"trace.element.ident\")]",
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "description": "The kind of the element. [req(\"trace.element.kind\")]",
          "allOf": [
            {
              "$ref": "#/definitions/ElementKind"
            }
          ]
        },
        "name": {
          "description": "The element name.\n\n**Note:** This is not the fully qualified identifier.",
          "type": "string"
        },
        "span": {
          "description": "The line span of the element. [req(\"trace.element.span\")]",
          "allOf": [
            {
              "$ref": "#/definitions/LineSpan"
            }
          ]
        }
      }
    },
    "ElementsOverview": {
      "type": "object",
      "required": [
        "files"
      ],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ElementsPerFile"
          }
        }
      }
    },
    "ElementsPerFile": {
      "type": "object",
      "required": [
        "elements",
        "file_hash",
        "filepath"
      ],
      "properties": {
        "elements": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ElementOverview"
          }
        },
        "file_hash": {
          "type": "string"
        },
        "filepath": {
          "type": "string"
        }
      }
    },
    "ExclusionAnnotationReference": {
      "type": "object",
      "required": [
        "comment",
        "def_line"
      ],
      "properties": {
        "comment": {
          "type": "string"
        },
        "def_line": {
          "description": "The line the exclude annotation was defined at.",
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "LineSpan": {
      "type": "object",
      "required": [
        "end",
        "start"
      ],
      "properties": {
        "end": {
          "type": "integer",
          "format": "int64"
        },
        "start": {
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "OverrideCoveredLineInfo": {
      "description": "Code coverage override of one or more lines. [req(\"review.coverage\")]",
      "type": "object",
      "required": [
        "comment",
        "nrs"
      ],
      "properties": {
        "comment": {
          "description": "Mandatory comment explaining the change to the code coverage information.",
          "type": "string"
        },
        "hits": {
          "description": "The new number of times the set lines are reached during a test run or test case execution. If None, the line is marked to be ignored from line coverage analysis.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int64"
        },
        "nrs": {
          "description": "The number of lines affected by this override.",
          "type": "array",
          "items": {
            "type": "integer",
            "format": "int64"
          }
        }
      }
    },
    "OverrideFileCoverage": {
      "description": "Code coverage overrides per file. [req(\"review.coverage\")]",
      "type": "object",
      "required": [
        "filepath"
      ],
      "properties": {
        "filepath": {
          "description": "The file whose coverage data is overridden in a review.",
          "type": "string"
        },
        "lines": {
          "description": "The line information in the file that is overridden.",
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/OverrideCoveredLineInfo"
          }
        }
      }
    },
    "OverrideTestCase": {
      "description": "Represents a test case state override in a review. [req(\"review.test_case_state\", \"review.coverage\")]",
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "coverage": {
          "description": "Overrides the code coverage related to this test case. [req(\"review.coverage\")]",
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/OverrideFileCoverage"
          }
        },
        "name": {
          "description": "Name of the test case whose state and/or related code coverage is overridden in a review.",
          "type": "string"
        },
        "state": {
          "description": "Overrides the state of the test case. [req(\"review.test_case_state\")]",
          "anyOf": [
            {
              "$ref": "#/definitions/OverrideTestCaseState"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "OverrideTestCaseState": {
      "description": "Represents a test case state override in a review. [req(\"review.test_case_state\")]",
      "type": "object",
      "required": [
        "comment",
        "new"
      ],
      "properties": {
        "comment": {
          "description": "Mandatory comment explaining why the state is overriden via review.",
          "type": "string"
        },
        "new": {
          "description": "The new state that is set with this override.",
          "allOf": [
            {
              "$ref": "#/definitions/TestState"
            }
          ]
        }
      }
    },
    "OverrideTestRun": {
      "description": "Represents review overrides for a specific test run. [req(\"review.test_case_state\", \"review.coverage\")]",
      "type": "object",
      "required": [
        "name",
        "utc_date"
      ],
      "properties": {
        "coverage": {
          "description": "List of file coverage overrides. [req(\"review.coverage\")]",
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/OverrideFileCoverage"
          }
        },
        "name": {
          "description": "Name of the test run.",
          "type": "string"
        },
        "test_cases": {
          "description": "List of test case state overrides. [req(\"review.test_case_state\")]",
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/OverrideTestCase"
          }
        },
        "utc_date": {
          "description": "The UTC date the test run execution started.",
          "type": "string"
        }
      }
    },
    "Product": {
      "description": "This struct defines the information *mantra* stores about a product.\n\nTODO: map to requirement",
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "base": {
          "description": "Optional baseline of the product. e.g. git branch or commit hash\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "description": "Optional description of the product.\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        },
        "homepage": {
          "description": "Optional link to the homepage of the product.\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "description": "The product ID.\n\nTODO: map to requirement",
          "type": "string"
        },
        "license": {
          "description": "Optional license of the product.\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "description": "The name of the product.\n\nTODO: map to requirement",
          "type": "string"
        },
        "properties": {
          "description": "Optional properties of the product.\n\nTODO: map to requirement",
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "repository": {
          "description": "Optional link to the repository of the product.\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "description": "Optional version of the product.\n\nTODO: map to requirement",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ProductOverviewReport": {
      "type": "object",
      "required": [
        "annotations",
        "product",
        "requirements",
        "reviews",
        "test_runs"
      ],
      "properties": {
        "annotations": {
          "$ref": "#/definitions/AnnotationsOverview"
        },
        "product": {
          "$ref": "#/definitions/Product"
        },
        "requirements": {
          "$ref": "#/definitions/RequirementsOverview"
        },
        "reviews": {
          "$ref": "#/definitions/ReviewsOverview"
        },
        "test_runs": {
          "$ref": "#/definitions/TestRunsOverview"
        }
      }
    },
    "ProductsSummary": {
      "type": "object",
      "required": [
        "requirements",
        "test_cases"
      ],
      "properties": {
        "requirements": {
          "$ref": "#/definitions/RequirementsSummary"
        },
        "test_cases": {
          "$ref": "#/definitions/TestCasesSummary"
        }
      }
    },
    "RequirementOverview": {
      "type": "object",
      "required": [
        "id",
        "manual_verification",
        "optional",
        "state",
        "title"
      ],
      "properties": {
        "base_origin": true,
        "children": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/RequirementReference"
          }
        },
        "covered_by": {
          "anyOf": [
            {
              "$ref": "#/definitions/CoveredByTestsOverview"
            },
            {
              "type": "null"
            }
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "manual_verification": {
          "type": "boolean"
        },
        "optional": {
          "type": "boolean"
        },
        "origin": true,
        "parents": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/RequirementReference"
          }
        },
        "reviewed_in": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/ReviewReference"
          }
        },
        "state": {
          "$ref": "#/definitions/RequirementState"
        },
        "title": {
          "type": "string"
        },
        "traces": {
          "anyOf": [
            {
              "$ref": "#/definitions/RequirementTracesOverview"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "RequirementReference": {
      "type": "object",
      "required": [
        "id",
        "optional",
        "state"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "optional": {
          "type": "boolean"
        },
        "product_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "$ref": "#/definitions/RequirementState"
        }
      }
    },
    "RequirementState": {
      "type": "string",
      "enum": [
        "failed",
        "verified",
        "skipped",
        "unverified",
        "deprecated",
        "ignored"
      ]
    },
    "RequirementTracesOverview": {
      "type": "object",
      "required": [
        "all",
        "summary"
      ],
      "properties": {
        "all": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TraceReference"
          }
        },
        "summary": {
          "$ref": "#/definitions/TracesSummary"
        }
      }
    },
    "RequirementsOverview": {
      "type": "object",
      "required": [
        "all",
        "roots",
        "summary"
      ],
      "properties": {
        "all": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RequirementOverview"
          }
        },
        "roots": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RequirementOverview"
          }
        },
        "summary": {
          "$ref": "#/definitions/RequirementsSummary"
        }
      }
    },
    "RequirementsSummary": {
      "type": "object",
      "required": [
        "deprecated",
        "failed",
        "ignored",
        "mandatory_verified",
        "manual_verification",
        "skipped",
        "total",
        "unverified",
        "verified"
      ],
      "properties": {
        "deprecated": {
          "$ref": "#/definitions/Aggregated"
        },
        "failed": {
          "$ref": "#/definitions/Aggregated"
        },
        "ignored": {
          "$ref": "#/definitions/Aggregated"
        },
        "mandatory_verified": {
          "description": "Metric for how many non-optional requirements are verified.",
          "allOf": [
            {
              "$ref": "#/definitions/Aggregated"
            }
          ]
        },
        "manual_verification": {
          "$ref": "#/definitions/Aggregated"
        },
        "skipped": {
          "$ref": "#/definitions/Aggregated"
        },
        "total": {
          "type": "integer",
          "format": "int64"
        },
        "unverified": {
          "$ref": "#/definitions/Aggregated"
        },
        "verified": {
          "$ref": "#/definitions/Aggregated"
        }
      }
    },
    "ResolvedCoveredFile": {
      "type": "object",
      "required": [
        "filepath",
        "lines"
      ],
      "properties": {
        "file_hash": {
          "description": "Optional hash of the file content to detect changes. Coverage formats may not provide the file hash, therefore it must be optional.",
          "type": [
            "string",
            "null"
          ]
        },
        "filepath": {
          "description": "File the coverage information is for.",
          "type": "string"
        },
        "lines": {
          "description": "Coverage information for a line in the file. [req(\"testcov.cov.lines\")]",
          "allOf": [
            {
              "$ref": "#/definitions/ResolvedCoveredLines"
            }
          ]
        }
      }
    },
    "ResolvedCoveredLine": {
      "description": "Coverage information of a line in a file. [req(\"testcov.cov.lines\")]",
      "type": "object",
      "required": [
        "nr",
        "state"
      ],
      "properties": {
        "nr": {
          "description": "The line number.",
          "type": "integer",
          "format": "int64"
        },
        "state": {
          "$ref": "#/definitions/ResolvedCoveredLineState"
        }
      }
    },
    "ResolvedCoveredLineState": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "uncovered"
          ]
        },
        {
          "type": "object",
          "required": [
            "covered"
          ],
          "properties": {
            "covered": {
              "type": "integer",
              "format": "int64"
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Line was excluded from coverage analysis. An optional reference to an exclusion annotation is given, if the exclusion was based on a mantra annotation.",
          "type": "object",
          "required": [
            "excluded"
          ],
          "properties": {
            "excluded": {
              "anyOf": [
                {
                  "$ref": "#/definitions/ExclusionAnnotationReference"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "overriden"
          ],
          "properties": {
            "overriden": {
              "type": "object",
              "required": [
                "comment",
                "review"
              ],
              "properties": {
                "comment": {
                  "type": "string"
                },
                "original_hits": {
                  "description": "The original hits that were collected from the tests.",
                  "type": [
                    "integer",
                    "null"
                  ],
                  "format": "int64"
                },
                "review": {
                  "$ref": "#/definitions/ReviewReference"
                },
                "set_hits": {
