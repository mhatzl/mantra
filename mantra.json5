{
  name: "mantra",
  license: "MIT",
  products: [{
    name: "$inherit",
    license: "$inherit",
    base: "main",
    requirements: [{
        path: "test-content/reqs/",
        source: "schema",
    }],
    annotations: [{
        path: "test-content/annotations/",
        source: "schema",
    },{
        path: "./",
        source: "content",
        pattern: "*.rs"
    }],
    test_runs: [{
        path: "target/nextest/default",
        source: {
            test: {
                format: "junit",
                pattern: "*junit.xml",
            },
            coverage: {
                format: "cobertura_loose",
                pattern: "*cobertura.xml",
            }
        }
    },{
        path: "test-content/test-runs/",
        source: "schema",
    }],
    reviews: [{
        path: "test-content/reviews/",
        source: "schema",
    }]
  }]
}
